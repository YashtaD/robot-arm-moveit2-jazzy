<?xml version="1.0"?>

<robot name="robot_arm"
       xmlns:xacro="http://www.ros.org/wiki/xacro">

  <link name="world"/>

  <link name="basement">

    <visual>
      <origin xyz="-0.5 -0.5 0"
              rpy="0 0 0"/>

      <geometry>
        <mesh filename="package://robot_arm_description/meshes/basement.STL"
              scale="0.01 0.01 0.01"/>
      </geometry>
    </visual>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>

      <inertia
        ixx="0.01"
        ixy="0.0"
        ixz="0.0"
        iyy="0.01"
        iyz="0.0"
        izz="0.01"/>
    </inertial>

  </link>
<link name="base_plate">

  <visual>
    <origin xyz="-0.39 -0.39 -0.56"
            rpy="0 0 0"/>

    <geometry>
      <mesh filename="package://robot_arm_description/meshes/base_plate.STL"
            scale="0.01 0.01 0.01"/>
    </geometry>
  </visual>

  <collision>
    <geometry>
      <cylinder radius="0.08" length="0.04"/>
    </geometry>
  </collision>

  <inertial>
    <mass value="0.8"/>

    <inertia
      ixx="0.01"
      ixy="0"
      ixz="0"
      iyy="0.01"
      iyz="0"
      izz="0.01"/>
  </inertial>

</link>

<link name="vertical_drive_arm">

  <visual>
    <origin xyz="0 0 0"
            rpy="0 1.5708 0"/>

    <geometry>
      <mesh filename="package://robot_arm_description/meshes/vertical_drive_arm.STL"
            scale="0.01 0.01 0.01"/>
    </geometry>

    <material name="yellow">
      <color rgba="1.0 1.0 0.0 1.0"/>
    </material>
  </visual>

  <collision>
    <origin xyz="0 0 0.075"
            rpy="0 0 0"/>

    <geometry>
      <box size="0.05 0.02 0.15"/>
    </geometry>
  </collision>

  <inertial>
    <origin xyz="0 0 0.075"
            rpy="0 0 0"/>

    <mass value="0.5"/>

    <inertia
      ixx="0.005"
      ixy="0"
      ixz="0"
      iyy="0.005"
      iyz="0"
      izz="0.005"/>
  </inertial>

</link>
<link name="shoulder_mount">

  <visual>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <geometry>
      <sphere radius="0.015"/>
    </geometry>
    <material name="green">
      <color rgba="0 1 0 1"/>
    </material>
  </visual>

</link>
  <!-- World to basement -->
  <joint name="world_to_basement" type="fixed">
    <parent link="world"/>
    <child link="basement"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Base rotation joint -->
  <joint name="joint1" type="revolute">
    <parent link="basement"/>
    <child link="base_plate"/>

    <origin xyz="0 0 0"
            rpy="0 0 0"/>

    <axis xyz="0 0 1"/>

    <limit
      lower="-3.14"
      upper="3.14"
      effort="10"
      velocity="1"/>
  </joint>

  <!-- Dummy shoulder mount attached to base plate -->
  <joint name="joint2_base_to_shoulder_mount" type="fixed">
    <parent link="base_plate"/>
    <child link="shoulder_mount"/>

    <origin xyz="0.04 -0.045 0.755"
            rpy="0 0 0"/>
  </joint>

  <!-- Vertical drive arm attached to dummy shoulder mount -->
  <joint name="joint3_shoulder_mount_to_vertical_drive_arm" type="fixed">
    <parent link="shoulder_mount"/>
    <child link="vertical_drive_arm"/>

    <origin xyz="0 0 0"
            rpy="0 0 0"/>
  </joint>
</robot>